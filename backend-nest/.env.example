# --- CONFIGURACIÓN DE SUPABASE ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-api-key

# --- CONFIGURACIÓN DE MERCADO PAGO ---
MP_ACCESS_TOKEN=tu-access-token
MP_PUBLIC_KEY=tu-public-key

# --- CONFIGURACIÓN DEL SERVIDOR ---
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# --- WEBHOOKS Y REDIRECCIONES ---
# Esta URL debe ser pública. Para desarrollo local, usa Ngrok.
MP_WEBHOOK_URL=https://tu-url-ngrok.app/payments/webhook

# --- CONFIGURACIÓN DE CORREO ELECTRÓNICO ---
# Para Gmail: genera una "Contraseña de Aplicación" en https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu-correo@gmail.com
MAIL_PASS=tu-contraseña-de-aplicacion
