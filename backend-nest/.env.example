# --- CONFIGURACIÓN DE SUPABASE ---
# Encuentra estos valores en: Settings > API
SUPABASE_URL=tu_url_aqui
SUPABASE_KEY=tu_anon_key_publica

# --- CONFIGURACIÓN DE MERCADO PAGO ---
# Encuentra estos valores en: Panel de Desarrollador de Mercado Pago
MP_ACCESS_TOKEN=tu_access_token_aqui
MP_PUBLIC_KEY=tu_public_key_aqui

# --- CONFIGURACIÓN DEL SERVIDOR ---
PORT=3000
NODE_ENV=development
